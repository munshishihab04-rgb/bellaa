# ============================================================
# RuSoftShop - Variabili d'ambiente
# Copia questo file in .env e compila i valori
# ============================================================

# Shopify Store Domain (es: licenvo.myshopify.com)
VITE_SHOPIFY_STORE_DOMAIN=licenvo.myshopify.com

# Shopify Storefront Access Token (pubblico)
# Ottienilo da: Shopify Admin > Apps > Develop apps > API credentials
VITE_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_token_here

# Porta del server di sviluppo (default: 3000)
PORT=3000

# Base path (default: /)
BASE_PATH=/
